{
  "name": "hush-voting-website",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "description": "HushVoting public website — privacy-first organizational voting platform",
  "scripts": {
    "dev": "vinxi dev",
    "build": "vinxi build",
    "start": "vinxi start",
    "test:unit": "vitest run",
    "test:e2e:happy-path": "playwright test --config tests/e2e/playwright.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-start": "1.168.27",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "playwright-bdd": "^9.2.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.0",
    "vinxi": "^0.5.0",
    "vite": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
