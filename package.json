{
  "name": "hush-voting-website",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "description": "HushVoting public website — privacy-first organizational voting platform",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "start": "node .output/server/index.mjs",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:happy-path": "playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:visual-baseline": "playwright test --config tests/e2e/playwright.config.ts --grep @Prerequisite",
    "test:e2e:protocol": "playwright test --config tests/e2e/playwright.config.ts --grep @FEAT-006",
    "test:e2e:footer": "playwright test --config tests/e2e/playwright.config.ts --grep @FEAT-007",
    "test:e2e:responsive": "playwright test --config tests/e2e/playwright.config.ts --grep @FEAT-008",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-start": "1.168.27",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.0.0",
    "jsdom": "^29.1.1",
    "nitro": "3.0.260610-beta",
    "playwright-bdd": "^9.2.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.0",
    "vite": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
