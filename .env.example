# HushVoting Website — Public Environment Variables
# Copy this file to .env and fill in values.
# These are safe for browser exposure (VITE_ prefix).

# Public site URL (used for canonical links and OG tags)
VITE_PUBLIC_SITE_URL=https://www.hushvoting.com

# HushVoting web client URL (used for cross-site navigation)
VITE_APP_SITE_URL=https://app.hushvoting.com

# HushServerNode public API base URL (used for live data in future features)
VITE_HUSHSERVERNODE_GRPC_URL=https://api.hushnetwork.social

# Marketing base URL (used for redirects)
VITE_MARKETING_BASE_URL=https://www.hushvoting.com

# Pilot access email delivery — server-side only, never expose with VITE_ prefix.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS="your-google-app-password"
PILOT_ACCESS_TO_EMAIL=aboimpinto@gmail.com
PILOT_ACCESS_FROM_EMAIL=your-gmail-address@gmail.com
PILOT_ACCESS_EMAIL_SUBJECT_PREFIX="[HushVoting Pilot Access]"
